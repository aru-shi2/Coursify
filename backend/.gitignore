# Dependencies
# Never commit node_modules; they are bulky and can be reinstalled via npm install
node_modules/
/client/node_modules/
/server/node_modules/

# Environment Variables
# Essential for hiding MongoDB connection strings and API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vite / Build Outputs
# Compiled production files should stay out of Git
dist/
dist-ssr/
*.local

# Logs
# Useful for debugging but shouldn't be in your repo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Editor / IDE settings
# Keeping these local prevents conflicts between teammates using different editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS Metadata
.DS_Store
Thumbs.db

# Testing
/coverage/

# Optional: TypeScript incremental build cache
*.tsbuildinfo